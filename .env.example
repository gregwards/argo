# Aver — Environment Configuration
# Copy to .env and fill in values

# Database
DB_PASSWORD=changeme_in_production

# LLM Providers
GOOGLE_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Voice
DEEPGRAM_API_KEY=your-deepgram-api-key

# WebRTC (SmallWebRTCTransport — no API keys needed)
# For production NAT traversal:
STUN_SERVERS=stun:stun.l.google.com:19302

# TURN Server (for NAT traversal on university networks)
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=aver
TURN_PASSWORD=changeme_turn_password

# Storage (optional for MVP — recordings stored locally if not configured)
S3_BUCKET=aver-recordings
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Auth
JWT_SECRET=change-this-to-a-random-256-bit-secret

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Aver <noreply@yourdomain.com>

# App
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
ENVIRONMENT=development
