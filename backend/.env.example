# Argo Backend — Environment Variables
# Copy to .env and fill in values. All vars are required unless marked (optional).

# Database — Railway auto-provides this; locally use docker-compose default
DATABASE_URL=postgresql+asyncpg://aver:changeme@localhost:5432/aver

# Auth — generate a random 256-bit secret (e.g. `openssl rand -hex 32`)
JWT_SECRET=CHANGE_ME

# Voice pipeline
DEEPGRAM_API_KEY=              # https://console.deepgram.com — STT
INWORLD_TTS_API_KEY=           # https://studio.inworld.ai — TTS
GOOGLE_API_KEY=                # https://console.cloud.google.com — Gemini LLM

# Daily.co — WebRTC transport
DAILY_API_KEY=                 # https://dashboard.daily.co

# Compiler & Profiler — Claude API
ANTHROPIC_API_KEY=             # https://console.anthropic.com

# Email — magic link delivery
RESEND_API_KEY=                # https://resend.com (optional — dev mode logs links to console)
RESEND_FROM_EMAIL=Argo <noreply@yourdomain.com>

# CORS — comma-separated allowed frontend origins
FRONTEND_URLS=http://localhost:3000,http://localhost:3001
# Magic link redirect base URL
FRONTEND_URL=http://localhost:3000

# Site gate — password for /dev and /instructor routes
SITE_PASSWORD=argo-dev

# App
ENVIRONMENT=development

# Storage (optional — recordings stored locally if not configured)
S3_BUCKET=aver-recordings
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
